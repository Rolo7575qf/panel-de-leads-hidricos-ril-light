# =======================================================
# GEMINI AI
# =======================================================
# Clave de API de Google AI Studio (requerida)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# =======================================================
# CLOUDFLARE D1 DATABASE
# =======================================================
# ID de tu cuenta de Cloudflare (Cloudflare Dashboard → lado derecho)
CLOUDFLARE_ACCOUNT_ID="YOUR_CLOUDFLARE_ACCOUNT_ID"

# ID de la base de datos D1 (Cloudflare → Workers & Pages → D1 → tu DB)
CLOUDFLARE_DATABASE_ID="YOUR_D1_DATABASE_ID"

# Token de API con permiso "D1:Edit" (Cloudflare → My Profile → API Tokens)
CLOUDFLARE_API_TOKEN="YOUR_CLOUDFLARE_API_TOKEN"

# =======================================================
# APP (opcional - para referencias internas)
# =======================================================
APP_URL="https://tu-proyecto.vercel.app"
